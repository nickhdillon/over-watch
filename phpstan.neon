includes:
    - vendor/larastan/larastan/extension.neon
    - vendor/nesbot/carbon/extension.neon

parameters:
    paths:
        - app/
        - bootstrap/app.php
        - config/
        - database/
        - routes/

    level: 5

    ignoreErrors:
        - '#Builder<App\\Models\\RecentView>::with\(\) expects.*MorphTo.*given#'
